-- Tipo: LocalScript
-- Ubicacion: StarterPlayer > StarterCharacterScripts
-- Se ejecuta en: Cliente
-- Nombre sugerido: PlanetGravityController

-- ModuleScript requerido: PlanetGravityMath
-- Ubicacion:
-- ReplicatedStorage > Modules > PlanetGravityMath
-- Proposito:
-- Funciones reutilizables para gravedad y movimiento tangencial.
-- Usado por:
-- - PlanetGravityController
--
-- ModuleScript requerido: PlanetRegistry
-- Ubicacion:
-- ReplicatedStorage > Modules > PlanetRegistry
-- Proposito:
-- Selecciona planeta activo por zonas de influencia y expone sus parametros.
-- Usado por:
-- - PlanetGravityController

local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local TweenService = game:GetService("TweenService")
local UserInputService = game:GetService("UserInputService")
local Lighting = game:GetService("Lighting")
local ReplicatedStorage = game:GetService("ReplicatedStorage")

local PlanetGravityMath
local PlanetRegistry
local usingFallbackMath = false
local usingFallbackRegistry = false
local MODULE_LOOKUP_TIMEOUT = 1.2

--[[
Funcion: findModuleInReplicatedStorage

Proposito:
Busca un ModuleScript por nombre en rutas comunes y de forma recursiva.

Precondiciones:
- moduleName debe ser string no vacio.

Requiere:
- ReplicatedStorage disponible.

Devuelve:
- ModuleScript o nil.
]]
local function findModuleInReplicatedStorage(moduleName, timeoutSeconds)
	local candidateNames = {moduleName, moduleName .. ".module"}
	local startedAt = os.clock()
	while (os.clock() - startedAt) <= timeoutSeconds do
		local modulesFolder = ReplicatedStorage:FindFirstChild("Modules")
		if modulesFolder then
			for _, candidateName in ipairs(candidateNames) do
				local fromModules = modulesFolder:FindFirstChild(candidateName)
				if fromModules and fromModules:IsA("ModuleScript") then
					return fromModules
				end
			end
		end

		for _, candidateName in ipairs(candidateNames) do
			local fromRoot = ReplicatedStorage:FindFirstChild(candidateName)
			if fromRoot and fromRoot:IsA("ModuleScript") then
				return fromRoot
			end
		end

		for _, candidateName in ipairs(candidateNames) do
			local fromDescendants = ReplicatedStorage:FindFirstChild(candidateName, true)
			if fromDescendants and fromDescendants:IsA("ModuleScript") then
				return fromDescendants
			end
		end

		task.wait(0.2)
	end

	return nil
end

-- Evita bloqueos infinitos si Modules o PlanetGravityMath no existen aun.
do
	local mathModule = findModuleInReplicatedStorage("PlanetGravityMath", MODULE_LOOKUP_TIMEOUT)

	if mathModule and mathModule:IsA("ModuleScript") then
		local ok, result = pcall(require, mathModule)
		if ok and type(result) == "table" then
			PlanetGravityMath = result
		else
			warn("PlanetGravityController: no se pudo require PlanetGravityMath, usando fallback local")
			usingFallbackMath = true
		end
	else
		warn("PlanetGravityController: no se encontro ReplicatedStorage/Modules/PlanetGravityMath, usando fallback local")
		usingFallbackMath = true
	end

	local registryModule = findModuleInReplicatedStorage("PlanetRegistry", MODULE_LOOKUP_TIMEOUT)

	if registryModule and registryModule:IsA("ModuleScript") then
		local ok, result = pcall(require, registryModule)
		if ok and type(result) == "table" then
			PlanetRegistry = result
		else
			warn("PlanetGravityController: no se pudo require PlanetRegistry, usando fallback local")
			usingFallbackRegistry = true
		end
	else
		warn("PlanetGravityController: no se encontro ReplicatedStorage/Modules/PlanetRegistry, usando fallback local")
		usingFallbackRegistry = true
	end

	if not PlanetGravityMath then
		PlanetGravityMath = {}

		function PlanetGravityMath.getGravityDirection(hrpPosition, centerPosition)
			local offset = centerPosition - hrpPosition
			if offset.Magnitude < 1e-5 then
				return Vector3.new(0, -1, 0)
			end
			return offset.Unit
		end

		function PlanetGravityMath.projectOnTangent(worldMove, upVector)
			return worldMove - upVector * worldMove:Dot(upVector)
		end
	end

	if not PlanetRegistry then
		PlanetRegistry = {}

		local function getPlanetSurfacePart(model)
			if not model or not model:IsA("Model") then
				return nil
			end

			local preferredName = model:GetAttribute("SurfacePartName")
			if type(preferredName) == "string" and preferredName ~= "" then
				local preferred = model:FindFirstChild(preferredName, true)
				if preferred and preferred:IsA("BasePart") then
					return preferred
				end
			end

			local sphere = model:FindFirstChild("Sphere", true)
			if sphere and sphere:IsA("BasePart") then
				return sphere
			end

			if model.PrimaryPart and model.PrimaryPart:IsA("BasePart") then
				return model.PrimaryPart
			end

			local bestPart = nil
			local bestVolume = -1
			for _, descendant in ipairs(model:GetDescendants()) do
				if descendant:IsA("BasePart") and descendant.Name ~= "GravityCenter" then
					local size = descendant.Size
					local volume = size.X * size.Y * size.Z
					if volume > bestVolume then
						bestVolume = volume
						bestPart = descendant
					end
				end
			end

			return bestPart
		end

		local function buildPlanetData(model, position)
			local gravityCenter = model:FindFirstChild("GravityCenter")
			local sphere = getPlanetSurfacePart(model)
			if not gravityCenter or not gravityCenter:IsA("BasePart") then
				return nil
			end
			if not sphere or not sphere:IsA("BasePart") then
				return nil
			end

			local radius = math.max(sphere.Size.X, sphere.Size.Y, sphere.Size.Z) * 0.5
			local centerDistance = (position - gravityCenter.Position).Magnitude
			local influenceRadius = radius * 3.2
			if centerDistance > influenceRadius then
				return nil
			end

			return {
				model = model,
				gravityCenter = gravityCenter,
				sphere = sphere,
				radius = radius,
				influenceRadius = influenceRadius,
				gravityAccel = 120,
				surfaceOffset = 3.9,
				centerDistance = centerDistance,
			}
		end

		function PlanetRegistry.getBestPlanetForPosition(position, workspaceRef)
			local planetsFolder = workspaceRef:FindFirstChild("Planets")
			if planetsFolder and planetsFolder:IsA("Folder") then
				local bestPlanetData = nil
				local bestDistanceToSurface = math.huge
				for _, child in ipairs(planetsFolder:GetChildren()) do
					local candidate = buildPlanetData(child, position)
					if candidate then
						local distanceToSurface = math.abs(candidate.centerDistance - candidate.radius)
						if distanceToSurface < bestDistanceToSurface then
							bestDistanceToSurface = distanceToSurface
							bestPlanetData = candidate
						end
					end
				end
				if bestPlanetData then
					return bestPlanetData
				end
			end

			local fallbackPlanet = workspaceRef:FindFirstChild("Planet")
			if fallbackPlanet then
				return buildPlanetData(fallbackPlanet, position)
			end

			return nil
		end
	end
end

if usingFallbackMath then
	warn("PlanetGravityController: fallback local activo (mismo calculo base de gravedad/tangente)")
end

if usingFallbackRegistry then
	warn("PlanetGravityController: fallback local de registro planetario activo")
end


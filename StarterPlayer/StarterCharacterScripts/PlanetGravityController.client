--[[
Funcion: findSkyByName

Proposito:
Buscar un objeto Sky por nombre en Lighting o en el almacen temporal local.

Precondiciones:
- skyName debe ser string no vacio.

Requiere:
- Lighting disponible.

Devuelve:
- Sky o nil.
]]
local function findSkyByName(skyName)
	if type(skyName) ~= "string" or skyName == "" then
		return nil
	end

	local lightingSky = Lighting:FindFirstChild(skyName)
	if lightingSky and lightingSky:IsA("Sky") then
		return lightingSky
	end

	local storedSky = skyStorageFolder:FindFirstChild(skyName)
	if storedSky and storedSky:IsA("Sky") then
		return storedSky
	end

	return nil
end

--[[
Funcion: warnMissingSkyOnce

Proposito:
Emitir una sola advertencia por sky faltante para evitar spam en consola.

Precondiciones:
- skyName debe ser string no vacio.

Requiere:
- skyWarnedByName inicializado.

Devuelve:
- nil
]]
local function warnMissingSkyOnce(skyName)
	if skyWarnedByName[skyName] then
		return
	end

	skyWarnedByName[skyName] = true
	warn("PlanetGravityController: no se encontro Sky '" .. skyName .. "' en Lighting")
end

--[[
Funcion: resetSkyFadeOverlay

Proposito:
Restaurar el overlay de fade a estado transparente e invisible.

Precondiciones:
- skyFadeFrame debe estar inicializado.

Requiere:
- Ninguno.

Devuelve:
- nil
]]
local function resetSkyFadeOverlay()
	skyFadeFrame.BackgroundTransparency = 1
	skyFadeFrame.Visible = false
end

--[[
Funcion: tweenSkyFade

Proposito:
Animar la opacidad del overlay usado para suavizar el cambio de sky.

Precondiciones:
- targetTransparency debe ser number valido entre 0 y 1.
- duration debe ser number mayor o igual a 0.

Requiere:
- skyFadeFrame inicializado.

Devuelve:
- nil
]]
local function tweenSkyFade(targetTransparency, duration)
	skyFadeFrame.Visible = true
	local tween = TweenService:Create(
		skyFadeFrame,
		TweenInfo.new(duration, Enum.EasingStyle.Quad, Enum.EasingDirection.Out),
		{ BackgroundTransparency = targetTransparency }
	)
	tween:Play()
	tween.Completed:Wait()
	if targetTransparency >= 1 then
		skyFadeFrame.Visible = false
	end
end

--[[
Funcion: applySkyModeImmediately

Proposito:
Aplicar el sky activo sin transicion, moviendo el sky inactivo al almacen local.

Precondiciones:
- mode debe ser "planet" o "space".

Requiere:
- El sky deseado debe existir.

Devuelve:
- boolean indicando si el cambio se aplico.
]]
local function applySkyModeImmediately(mode)
	local desiredSkyName = mode == "planet" and PLANET_SKY_NAME or SPACE_SKY_NAME
	local inactiveSkyName = mode == "planet" and SPACE_SKY_NAME or PLANET_SKY_NAME
	local desiredSky = findSkyByName(desiredSkyName)
	if not desiredSky then
		warnMissingSkyOnce(desiredSkyName)
		return false
	end

	local inactiveSky = findSkyByName(inactiveSkyName)
	if inactiveSky and inactiveSky ~= desiredSky then
		inactiveSky.Parent = skyStorageFolder
	end

	desiredSky.Parent = Lighting
	activeSkyMode = mode
	return true
end

--[[
Funcion: setSkyMode

Proposito:
Activar el sky correspondiente al estado actual: planeta o espacio.

Precondiciones:
- mode debe ser "planet" o "space".

Requiere:
- Los objetos Sky deben existir en Lighting al menos una vez para poder encontrarlos.

Devuelve:
- nil
]]
local function setSkyMode(mode)
	if mode ~= "planet" and mode ~= "space" then
		return
	end

	if activeSkyMode == mode or pendingSkyMode == mode then
		return
	end

	if activeSkyMode == nil and not skyTransitionInProgress then
		if applySkyModeImmediately(mode) then
			resetSkyFadeOverlay()
		end
		return
	end

	pendingSkyMode = mode
	if skyTransitionInProgress then
		return
	end

	skyTransitionInProgress = true
	task.spawn(function()
		while pendingSkyMode and pendingSkyMode ~= activeSkyMode do
			local targetMode = pendingSkyMode
			pendingSkyMode = nil

			tweenSkyFade(0, SKY_FADE_OUT_TIME)
			local changed = applySkyModeImmediately(targetMode)
			if not changed then
				resetSkyFadeOverlay()
				break
			end

			if SKY_FADE_HOLD_TIME > 0 then
				task.wait(SKY_FADE_HOLD_TIME)
			end

			tweenSkyFade(1, SKY_FADE_IN_TIME)
		end

		skyTransitionInProgress = false
		if skyFadeFrame.BackgroundTransparency < 1 then
			resetSkyFadeOverlay()
		end
	end)
end

--[[
Funcion: tryResolveActivePlanet

Proposito:
Resuelve el planeta activo segun la posicion del jugador y zonas de influencia.

Precondiciones:
- PlanetRegistry.getBestPlanetForPosition debe existir.

Requiere:
- Planetas en Workspace/Planets o fallback Workspace/Planet.

Devuelve:
- boolean indicando si hay planeta activo.
]]
local function tryResolveActivePlanet()
	local bestPlanet = PlanetRegistry.getBestPlanetForPosition(hrp.Position, workspace)
	if not bestPlanet then
		if activePlanetData then
			warn("PlanetGravityController: sin planeta activo, gravedad desactivada temporalmente")
		end
		setSkyMode("space")
		activePlanetData = nil
		desiredRadiusFromCenter = nil
		warnedInsideSphere = false
		hasSnappedToSurface = false
		return false
	end

	if not activePlanetData or activePlanetData.model ~= bestPlanet.model then
		warn("PlanetGravityController: planeta activo -> " .. bestPlanet.model.Name)
		setSkyMode("planet")
		activePlanetData = bestPlanet
		desiredRadiusFromCenter = bestPlanet.radius + bestPlanet.surfaceOffset
		warnedInsideSphere = false
		hasSnappedToSurface = false
	else
		setSkyMode("planet")
		activePlanetData = bestPlanet
		if not desiredRadiusFromCenter then
			desiredRadiusFromCenter = bestPlanet.radius + bestPlanet.surfaceOffset
		end
	end

	return true
end

--[[
Funcion: updateKey

Proposito:
Actualiza el estado de teclas WASD para construir movimiento local.

Precondiciones:
- keyCode debe venir de UserInputService.

Requiere:
- inputState inicializado.

Devuelve:
- nil
]]
local function updateKey(keyCode, value)
	if keyCode == Enum.KeyCode.W then inputState.W = value end
	if keyCode == Enum.KeyCode.A then inputState.A = value end
	if keyCode == Enum.KeyCode.S then inputState.S = value end
	if keyCode == Enum.KeyCode.D then inputState.D = value end
end

--[[
Funcion: getLocalMoveVector

Proposito:
Convierte estado WASD a un vector local normalizado.

Precondiciones:
- inputState actualizado por eventos de teclado.

Requiere:
- Ninguno.

Devuelve:
- Vector3 local.
]]
local function getLocalMoveVector()
	local x = (inputState.D and 1 or 0) - (inputState.A and 1 or 0)
	local z = (inputState.S and 1 or 0) - (inputState.W and 1 or 0)
	local v = Vector3.new(x, 0, z)
	if v.Magnitude > 1 then
		v = v.Unit
	end
	return v
end

--[[
Funcion: getControlsMoveVector

Proposito:
Obtiene el vector de movimiento local (X/Z) desde PlayerModule Controls,
que es mas estable en movil que depender de Humanoid.MoveDirection.

Precondiciones:
- controlsInterface puede ser nil si PlayerModule no esta disponible.

Devuelve:
- Vector3 local o nil.
]]
local function getControlsMoveVector()
	if not controlsInterface or type(controlsInterface.GetMoveVector) ~= "function" then
		return nil
	end

	local ok, moveVector = pcall(function()
		return controlsInterface:GetMoveVector()
	end)

	if not ok or typeof(moveVector) ~= "Vector3" then
		return nil
	end

	local localMove = Vector3.new(moveVector.X, 0, moveVector.Z)
	if localMove.Magnitude > 1 then
		localMove = localMove.Unit
	end

	if localMove.Magnitude < 1e-3 then
		return nil
	end

	return localMove
end

--[[
Funcion: getCombinedMoveVector

Proposito:
Combina teclado WASD con el vector local de PlayerModule Controls en movil.
Si Controls no esta disponible, usa Humanoid.MoveDirection como fallback.
Cuando hay teclado activo, tiene prioridad para no afectar desktop.

Precondiciones:
- cameraRight, cameraForward y upVector deben ser Vector3 validos.

Requiere:
- PlanetGravityMath.projectOnTangent.

Devuelve:
- Vector3 local x/z normalizado.
]]
local function getCombinedMoveVector(cameraRight, cameraForward, upVector)
	local keyboardMove = getLocalMoveVector()
	if keyboardMove.Magnitude > 0.01 then
		lastMobileTangentMove = Vector3.zero
		lastMobileMoveTime = -100
		return keyboardMove
	end

	local controlsMove = getControlsMoveVector()
	if controlsMove and controlsMove.Magnitude > 1e-3 then
		local tangentFromControls = (cameraRight * controlsMove.X) + (cameraForward * -controlsMove.Z)
		tangentFromControls = PlanetGravityMath.projectOnTangent(tangentFromControls, upVector)
		if tangentFromControls and tangentFromControls.Magnitude >= 1e-3 then
			lastMobileTangentMove = tangentFromControls
			lastMobileMoveTime = os.clock()
		end
		return controlsMove
	end

	local moveDirection = humanoid.MoveDirection
	local tangentMove = nil
	if moveDirection.Magnitude >= 1e-3 then
		tangentMove = PlanetGravityMath.projectOnTangent(moveDirection, upVector)
		if tangentMove and tangentMove.Magnitude >= 1e-3 then
			lastMobileTangentMove = tangentMove
			lastMobileMoveTime = os.clock()
		end
	end

	if not tangentMove or tangentMove.Magnitude < 1e-3 then
		if (os.clock() - lastMobileMoveTime) <= MOBILE_MOVE_GRACE_TIME and lastMobileTangentMove.Magnitude >= 1e-3 then
			tangentMove = lastMobileTangentMove
		else
			return Vector3.zero
		end
	end

	if tangentMove.Magnitude < 1e-3 then
		return Vector3.zero
	end

	local localX = tangentMove:Dot(cameraRight)
	local localZ = -tangentMove:Dot(cameraForward)
	local combined = Vector3.new(localX, 0, localZ)
	if combined.Magnitude > 1 then
		combined = combined.Unit
	end

	return combined
end

--[[
Funcion: tryInitializeControlsInterface

Proposito:
Inicializa (o reintenta inicializar) PlayerModule:GetControls para leer
input movil de forma estable en gravedad planetaria.

Devuelve:
- boolean indicando si controlsInterface quedo disponible.
]]
local function tryInitializeControlsInterface()
	if controlsInterface then
		return true
	end

	local playerScripts = player:FindFirstChild("PlayerScripts")
	if not playerScripts then
		return false
	end

	local playerModuleScript = playerScripts:FindFirstChild("PlayerModule")
	if not playerModuleScript or not playerModuleScript:IsA("ModuleScript") then
		return false
	end

	local okModule, playerModule = pcall(require, playerModuleScript)
	if not okModule or type(playerModule) ~= "table" or type(playerModule.GetControls) ~= "function" then
		return false
	end

	local okControls, controls = pcall(function()
		return playerModule:GetControls()
	end)
	if not okControls or not controls then
		return false
	end

	controlsInterface = controls
	return true
end

--[[
Funcion: getProjectedUnit

Proposito:
Proyecta un vector en la tangente y lo normaliza si su magnitud es valida.

Precondiciones:
- vector y upVector deben ser Vector3 validos.

Requiere:
- PlanetGravityMath.projectOnTangent disponible.

Devuelve:
- Vector3 unitario o nil si no hay direccion valida.
]]
local function getProjectedUnit(vector, upVector)
	local projected = PlanetGravityMath.projectOnTangent(vector, upVector)
	if not projected or projected.Magnitude < 1e-5 then
		return nil
	end
	return projected.Unit
end

--[[
Funcion: getGroundHit

Proposito:
Detecta suelo local en direccion de gravedad para estabilizar estados y adhesion.

Precondiciones:
- hrp y gravityDir deben ser validos.

Requiere:
- Workspace con colision del planeta habilitada.

Devuelve:
- RaycastResult o nil.
]]
local function getGroundHit(gravityDir)
	local hit = workspace:Raycast(hrp.Position, gravityDir * GROUND_RAY_LENGTH, groundRayParams)
	if not hit then
		return nil
	end
	if not activePlanetData or not activePlanetData.model then
		return nil
	end
	if hit.Instance and hit.Instance:IsDescendantOf(activePlanetData.model) then
		if desiredRadiusFromCenter and activePlanetData.gravityCenter then
			local hitRadius = (hit.Position - activePlanetData.gravityCenter.Position).Magnitude
			if hitRadius > (activePlanetData.radius + 60) then
				return nil
			end
		end
		return hit
	end
	return nil
end

--[[
Funcion: isNearSurface

Proposito:
Determina si el personaje esta suficientemente cerca de la superficie objetivo.

Precondiciones:
- centerDistance y desiredRadiusFromCenter deben ser numeros validos.

Requiere:
- Ninguno.

Devuelve:
- boolean.
]]
local function isNearSurface(centerDistance)
	if not desiredRadiusFromCenter then
		return false
	end
	return math.abs(centerDistance - desiredRadiusFromCenter) <= SURFACE_NEAR_BAND
end

--[[
Funcion: updateOrbitCamera

Proposito:
Actualiza la camara third-person alrededor del personaje usando un up vector dado.

Precondiciones:
- upVector debe ser un Vector3 valido.

Requiere:
- camera y hrp disponibles.

Devuelve:
- Vector3 con la direccion forward usada por la camara.
]]
local function updateOrbitCamera(upVector, dt)
	if not cameraPlanarForward then
		cameraPlanarForward = getProjectedUnit(hrp.CFrame.LookVector, upVector) or Vector3.new(0, 0, -1)
	end

	if math.abs(cameraYawDelta) > 1e-6 then
		local yawCFrame = CFrame.fromAxisAngle(upVector, cameraYawDelta)
		local rotated = yawCFrame:VectorToWorldSpace(cameraPlanarForward)
		local projected = getProjectedUnit(rotated, upVector)
		if projected then
			if cameraPlanarForward and projected:Dot(cameraPlanarForward) < 0 then
				projected = -projected
			end
			cameraPlanarForward = projected
		end
		cameraYawDelta = 0
	else
		local projected = getProjectedUnit(cameraPlanarForward, upVector)
		if projected then
			if cameraPlanarForward and projected:Dot(cameraPlanarForward) < 0 then
				projected = -projected
			end
			cameraPlanarForward = projected
		end
	end

	local cameraLookDirection = ((cameraPlanarForward * math.cos(cameraPitch)) + (upVector * math.sin(cameraPitch))).Unit
	local lookTarget = hrp.Position + upVector * CAMERA_LOOK_OFFSET
	local desiredCameraPos = lookTarget - cameraLookDirection * CAMERA_DISTANCE + upVector * CAMERA_HEIGHT
	local desiredCameraCFrame = CFrame.lookAt(desiredCameraPos, lookTarget, upVector)
	local cameraBlend = math.clamp(CAMERA_SMOOTH * dt, 0, 1)
	camera.CFrame = camera.CFrame:Lerp(desiredCameraCFrame, cameraBlend)
	return cameraLookDirection
end

--[[
Funcion: getAnimationId

Proposito:
Obtiene el AnimationId desde fuentes externas y aplica fallback.

Precondiciones:
- animationName debe ser "Idle", "Walk" o "Jump".

Requiere:
- Animator en el Humanoid.

Devuelve:
- string con AnimationId valido o nil.
]]
local function getAnimationId(animationName)
	-- Fuente 1: carpeta recomendada ReplicatedStorage/Animations
	local animationsFolder = ReplicatedStorage:FindFirstChild("Animations")
	if animationsFolder then
		local animationObject = animationsFolder:FindFirstChild(animationName)
		if animationObject and animationObject:IsA("Animation") and animationObject.AnimationId ~= "" then
			return animationObject.AnimationId
		end
	end

	-- Fuente 2: script Animate copiado en ReplicatedStorage (solo como contenedor de assets)
	local animateScript = ReplicatedStorage:FindFirstChild("Animate")
	if animateScript then
		local folderName = "walk"
		if animationName == "Idle" then
			folderName = "idle"
		elseif animationName == "Jump" then
			folderName = "jump"
		end
		local animationSetFolder = animateScript:FindFirstChild(folderName)
		if animationSetFolder then
			for _, child in ipairs(animationSetFolder:GetChildren()) do
				if child:IsA("Animation") and child.AnimationId ~= "" then
					return child.AnimationId
				end
			end
		end
	end

	return DEFAULT_ANIMATION_IDS[animationName]
end

--[[
Funcion: ensureTrack

Proposito:
Carga una pista de animacion si aun no existe en cache.

Precondiciones:
- name debe existir en DEFAULT_ANIMATION_IDS o en ReplicatedStorage/Animations.

Requiere:
- animator valido.

Devuelve:
- AnimationTrack o nil.
]]
local function ensureTrack(name)
	if animationTracks[name] then
		return animationTracks[name]
	end

	local animationId = getAnimationId(name)
	if not animationId then
		warn("PlanetGravityController: no se encontro AnimationId para " .. name)
		return nil
	end

	local animation = Instance.new("Animation")
	animation.AnimationId = animationId

	local ok, track = pcall(function()
		return animator:LoadAnimation(animation)
	end)

	if not ok or not track then
		warn("PlanetGravityController: no se pudo cargar animacion " .. name)
		return nil
	end

	if name == "Jump" then
		track.Priority = Enum.AnimationPriority.Action
	else
		track.Priority = Enum.AnimationPriority.Movement
	end
	animationTracks[name] = track
	return track
end

--[[
Funcion: playLocomotionAnimation

Proposito:
Reproduce animacion Idle/Walk/Jump de forma manual segun estado de movimiento.

Precondiciones:
- tangentSpeed, isGrounded y radialSpeed calculados por frame.

Requiere:
- Tracks cargadas o fallback disponible.

Devuelve:
- nil
]]
local function playLocomotionAnimation(tangentSpeed, isGrounded, radialSpeed, moveInputMagnitude)
	local targetName = "Idle"
	if not isGrounded and radialSpeed > 2 then
		targetName = "Jump"
	elseif isGrounded and tangentSpeed > 1.5 and (moveInputMagnitude or 0) > 0.1 then
		targetName = "Walk"
	end

	if currentAnimationName ~= targetName then
		for name, track in pairs(animationTracks) do
			if track.IsPlaying and name ~= targetName then
				track:Stop(0.15)
			end
		end

		local targetTrack = ensureTrack(targetName)
		if targetTrack and not targetTrack.IsPlaying then
			targetTrack:Play(0.15)
		end
		currentAnimationName = targetName
	end

	if targetName == "Walk" then
		local walkTrack = ensureTrack("Walk")
		if walkTrack then
			local speedScale = math.clamp(tangentSpeed / MOVE_SPEED, 0.65, 1.4)
			walkTrack:AdjustSpeed(speedScale)
		end
	end
end

--[[
Funcion: clearMovementInput

Proposito:
Limpia estados de input para evitar teclas "pegadas" cuando se pierde foco o al alternar modos.

Precondiciones:
- inputState inicializado.

Requiere:
- Ninguno.

Devuelve:
- nil.
]]
local function clearMovementInput()
	inputState.W = false
	inputState.A = false
	inputState.S = false
	inputState.D = false
	flyUp = false
	flyDown = false
end

--[[
Funcion: shouldUseTouchForCamera

Proposito:
Restringir el control de camara tactil al lado derecho para no interferir
con el joystick virtual de movimiento en movil.

Precondiciones:
- touchInput debe ser InputObject de tipo Touch.

Requiere:
- camera disponible.

Devuelve:
- boolean.
]]
local function shouldUseTouchForCamera(touchInput)
	if touchInput.UserInputType ~= Enum.UserInputType.Touch then
		return false
	end

	local viewport = camera and camera.ViewportSize or Vector2.new(1280, 720)
	return touchInput.Position.X >= (viewport.X * 0.45)
end

UserInputService.InputBegan:Connect(function(input, gameProcessed)
	if gameProcessed then
		return
	end
	if TEST_FLY_ENABLED and input.KeyCode == TEST_FLY_TOGGLE_KEY then
		isFlyMode = not isFlyMode
		if isFlyMode then
			warn("PlanetGravityController: TEST FLY ON")
			humanoid:ChangeState(Enum.HumanoidStateType.Physics)
			clearMovementInput()
		else
			warn("PlanetGravityController: TEST FLY OFF")
			tryResolveActivePlanet()
			if not activePlanetData then
				hrp.AssemblyLinearVelocity = Vector3.zero
			end
			hasSnappedToSurface = false
			clearMovementInput()
		end
		return
	end
	if input.UserInputType == Enum.UserInputType.MouseButton2 then
		isRightMouseDown = true
		UserInputService.MouseBehavior = Enum.MouseBehavior.LockCurrentPosition
		return
	end
	if input.KeyCode == Enum.KeyCode.Space then
		if isFlyMode then
			flyUp = true
			return
		end
		jumpRequested = true
	end
	if isFlyMode and (input.KeyCode == Enum.KeyCode.LeftControl or input.KeyCode == Enum.KeyCode.C) then
		flyDown = true
		return
	end
	updateKey(input.KeyCode, true)
end)

UserInputService.InputEnded:Connect(function(input)
	if input.UserInputType == Enum.UserInputType.MouseButton2 then
		isRightMouseDown = false
		UserInputService.MouseBehavior = Enum.MouseBehavior.Default
		return
	end
	if input.KeyCode == Enum.KeyCode.Space then
		flyUp = false
	end
	if input.KeyCode == Enum.KeyCode.LeftControl or input.KeyCode == Enum.KeyCode.C then
		flyDown = false
	end
	updateKey(input.KeyCode, false)
end)

UserInputService.InputChanged:Connect(function(input, gameProcessed)
	if gameProcessed then
		return
	end
	if input.UserInputType == Enum.UserInputType.MouseMovement and isRightMouseDown then
		cameraYawDelta -= input.Delta.X * CAMERA_MOUSE_SENSITIVITY
		cameraPitch = math.clamp(
			cameraPitch - (input.Delta.Y * CAMERA_MOUSE_SENSITIVITY),
			CAMERA_PITCH_MIN,
			CAMERA_PITCH_MAX
		)
		return
	end

end)

UserInputService.TouchStarted:Connect(function(touchInput, gameProcessed)
	if gameProcessed then
		return
	end

	if activeLookTouchInput then
		return
	end

	if shouldUseTouchForCamera(touchInput) then
		activeLookTouchInput = touchInput
		lastLookTouchPos = touchInput.Position
	end
end)

UserInputService.TouchMoved:Connect(function(touchInput, gameProcessed)
	if gameProcessed then
		return
	end

	if touchInput ~= activeLookTouchInput then
		return
	end

	if not lastLookTouchPos then
		lastLookTouchPos = touchInput.Position
		return
	end

	local delta = touchInput.Position - lastLookTouchPos
	lastLookTouchPos = touchInput.Position

	cameraYawDelta -= delta.X * CAMERA_TOUCH_SENSITIVITY
	cameraPitch = math.clamp(
		cameraPitch - (delta.Y * CAMERA_TOUCH_SENSITIVITY),
		CAMERA_PITCH_MIN,
		CAMERA_PITCH_MAX
	)
end)

UserInputService.TouchEnded:Connect(function(touchInput, _gameProcessed)
	if touchInput == activeLookTouchInput then
		activeLookTouchInput = nil
		lastLookTouchPos = nil
	end
end)

UserInputService.WindowFocusReleased:Connect(function()
	clearMovementInput()
end)

humanoid.AutoRotate = false
camera.CameraType = Enum.CameraType.Scriptable

--[[
Funcion: disableHumanoidLocomotion

Proposito:
Desactiva completamente la locomocion interna del Humanoid para evitar
conflictos con el controlador de gravedad planetaria.

Precondiciones:
- humanoid debe existir.
- El movimiento debe ser controlado 100% por fisica custom.

Requiere:
- Ejecutarse una sola vez al iniciar el script.

Devuelve:
- nil
]]
local function disableHumanoidLocomotion()
	humanoid.WalkSpeed = 0
	humanoid.JumpPower = 0
	humanoid.AutoRotate = false

	humanoid:ChangeState(Enum.HumanoidStateType.Physics)

	humanoid:SetStateEnabled(Enum.HumanoidStateType.Running, false)
	humanoid:SetStateEnabled(Enum.HumanoidStateType.RunningNoPhysics, false)
	humanoid:SetStateEnabled(Enum.HumanoidStateType.Freefall, false)
	humanoid:SetStateEnabled(Enum.HumanoidStateType.FallingDown, false)
	humanoid:SetStateEnabled(Enum.HumanoidStateType.Jumping, false)
	humanoid:SetStateEnabled(Enum.HumanoidStateType.Climbing, false)
end

disableHumanoidLocomotion()
tryResolveActivePlanet()
if UserInputService.TouchEnabled and not tryInitializeControlsInterface() then
	warn("PlanetGravityController: Controls movil no listo al iniciar, reintentando en background")
end

RunService.RenderStepped:Connect(function(dt)
	if UserInputService.TouchEnabled and not controlsInterface then
		controlsInitRetryAcc += dt
		if controlsInitRetryAcc >= CONTROLS_INIT_RETRY_INTERVAL then
			controlsInitRetryAcc = 0
			tryInitializeControlsInterface()
		end
	end

	planetScanAcc += dt
	if planetScanAcc >= PLANET_SCAN_INTERVAL then
		planetScanAcc = 0
		tryResolveActivePlanet()
	end

	if isFlyMode then
		local upVector = lastUpVector
		local cameraForward = updateOrbitCamera(upVector, dt)
		local cameraRight = cameraForward:Cross(upVector)
		if cameraRight.Magnitude < 1e-5 then
			cameraRight = camera.CFrame.RightVector
		else
			cameraRight = cameraRight.Unit
		end

		local flyDir = Vector3.zero
		if inputState.W then flyDir += cameraForward end
		if inputState.S then flyDir -= cameraForward end
		if inputState.D then flyDir += cameraRight end
		if inputState.A then flyDir -= cameraRight end
		if flyUp then flyDir += upVector end
		if flyDown then flyDir -= upVector end

		if flyDir.Magnitude > 1 then
			flyDir = flyDir.Unit
		end

		local flySpeed = TEST_FLY_SPEED
		if UserInputService:IsKeyDown(Enum.KeyCode.LeftShift) then
			flySpeed *= TEST_FLY_FAST_MULT
		end

		hrp.AssemblyLinearVelocity = flyDir * flySpeed
		hrp.CFrame = CFrame.lookAt(hrp.Position, hrp.Position + cameraForward, upVector)
		playLocomotionAnimation(0, false, 0, 0)
		return
	end

	if not activePlanetData then
		local dampFactor = math.clamp(1 - (SPACE_LINEAR_DAMPING * dt), 0, 1)
		hrp.AssemblyLinearVelocity *= dampFactor

		local upVector = lastUpVector
		updateOrbitCamera(upVector, dt)
		return
	end

	local gravityCenter = activePlanetData.gravityCenter
	local gravityAccel = activePlanetData.gravityAccel
	local planetRadius = activePlanetData.radius
	if not gravityCenter or not gravityCenter.Parent then
		activePlanetData = nil
		return
	end

	-- Direccion hacia centro de gravedad
	local gravityDir = PlanetGravityMath.getGravityDirection(hrp.Position, gravityCenter.Position)
	if gravityDir == Vector3.zero then
		warn("PlanetGravityController: Dirección de gravedad inválida, usando fallback")
		gravityDir = Vector3.new(0, -1, 0)
	end
	local upVector = -gravityDir
	lastUpVector = upVector

	-- Construye una base estable para evitar flips bruscos al pasar polos.
	if not surfaceForward then
		surfaceForward = getProjectedUnit(hrp.CFrame.LookVector, upVector)
		if not surfaceForward then
			surfaceForward = getProjectedUnit(Vector3.new(0, 0, -1), upVector)
		end
	end

	if not cameraPlanarForward then
		cameraPlanarForward = surfaceForward
	end

	updateOrbitCamera(upVector, dt)

	local moveCameraForward = getProjectedUnit(camera.CFrame.LookVector, upVector)
	if not moveCameraForward then
		moveCameraForward = cameraPlanarForward
	end
	if not moveCameraForward then
		moveCameraForward = surfaceForward
	end
	if not moveCameraForward then
		return
	end

	local moveCameraRight = getProjectedUnit(camera.CFrame.RightVector, upVector)
	if not moveCameraRight then
		moveCameraRight = moveCameraForward:Cross(upVector)
		if moveCameraRight.Magnitude >= 1e-5 then
			moveCameraRight = moveCameraRight.Unit
		else
			moveCameraRight = nil
		end
	end
	if not moveCameraRight then
		return
	end

	local localMove = getCombinedMoveVector(moveCameraRight, moveCameraForward, upVector)
	local desiredMove = (moveCameraRight * localMove.X) + (moveCameraForward * -localMove.Z)
	local groundHit = getGroundHit(gravityDir)
	local centerDistance = (hrp.Position - gravityCenter.Position).Magnitude
	if groundHit and desiredRadiusFromCenter then
		local hitRadius = (groundHit.Position - gravityCenter.Position).Magnitude
		local desiredFromHit = hitRadius + activePlanetData.surfaceOffset
		local surfaceBlend = math.clamp(SURFACE_RADIUS_BLEND * dt, 0, 1)
		desiredRadiusFromCenter = desiredRadiusFromCenter + ((desiredFromHit - desiredRadiusFromCenter) * surfaceBlend)
	end
	local isGrounded = (groundHit ~= nil) or isNearSurface(centerDistance)

	local facingTarget = surfaceForward
	if desiredMove.Magnitude > 0 then
		facingTarget = desiredMove.Unit
	end

	local facingBlend = math.clamp(FACING_RESPONSE * dt, 0, 1)
	local blendedFacing = surfaceForward:Lerp(facingTarget, facingBlend)
	local projectedFacing = getProjectedUnit(blendedFacing, upVector)
	if projectedFacing then
		if surfaceForward and projectedFacing:Dot(surfaceForward) < 0 then
			projectedFacing = -projectedFacing
		end
		surfaceForward = projectedFacing
	end

	local rightVector = surfaceForward:Cross(upVector)
	if rightVector.Magnitude < 1e-5 then
		rightVector = getProjectedUnit(hrp.CFrame.RightVector, upVector)
	else
		rightVector = rightVector.Unit
	end
	if not rightVector then
		return
	end

	surfaceForward = upVector:Cross(rightVector).Unit
	hrp.CFrame = CFrame.lookAt(hrp.Position, hrp.Position + surfaceForward, upVector)

	-- Movimiento tangencial con velocidad objetivo para evitar acumulacion inestable.
	desiredMove = (moveCameraRight * localMove.X) + (moveCameraForward * -localMove.Z)

	local currentVel = hrp.AssemblyLinearVelocity
	local radialSpeed = currentVel:Dot(upVector)
	local radialVel = upVector * radialSpeed
	local tangentVel = currentVel - radialVel

	local targetTangent = Vector3.zero
	if desiredMove.Magnitude > 0 then
		targetTangent = desiredMove.Unit * MOVE_SPEED
	end

	local response = MOVE_RESPONSE
	if localMove.Magnitude <= 0 then
		response *= NO_INPUT_RESPONSE_MULT
	end

	local blend = math.clamp(response * dt, 0, 1)
	local newTangent = tangentVel:Lerp(targetTangent, blend)
	if localMove.Magnitude <= 0 then
		local brakeBlend = math.clamp(IDLE_TANGENT_BRAKE * dt, 0, 1)
		newTangent = newTangent:Lerp(Vector3.zero, brakeBlend)
		if newTangent.Magnitude < 0.35 then
			newTangent = Vector3.zero
		end
	end
	if newTangent.Magnitude > MAX_TANGENT_SPEED then
		newTangent = newTangent.Unit * MAX_TANGENT_SPEED
	end

	local radialError = desiredRadiusFromCenter - centerDistance

	if not hasSnappedToSurface and math.abs(radialError) > MAX_SPAWN_RADIAL_ERROR then
		local snappedPosition = gravityCenter.Position + (upVector * desiredRadiusFromCenter)
		hrp.CFrame = CFrame.lookAt(snappedPosition, snappedPosition + surfaceForward, upVector)
		hrp.AssemblyLinearVelocity = Vector3.zero
		hasSnappedToSurface = true
		return
	end

	-- Control radial tipo resorte-amortiguador para mantener al personaje pegado a la esfera.
	local radialAccel = -gravityAccel + (radialError * SURFACE_SPRING) - (radialSpeed * SURFACE_DAMPING)
	local newRadialSpeed = radialSpeed + radialAccel * dt
	newRadialSpeed = math.clamp(newRadialSpeed, -MAX_RADIAL_SPEED, MAX_RADIAL_SPEED)
	if centerDistance > (desiredRadiusFromCenter + 5) then
		newRadialSpeed = math.min(newRadialSpeed, 0)
	end

	if jumpRequested and isGrounded and (os.clock() - lastJumpTime) >= JUMP_COOLDOWN then
		newRadialSpeed = math.max(newRadialSpeed, JUMP_IMPULSE)
		lastJumpTime = os.clock()
	end
	local wantsJump = jumpRequested
	jumpRequested = false

	-- Evita deriva cuando no hay input: elimina velocidades residuales al estar en suelo.
	if localMove.Magnitude <= 0 and isGrounded then
		if math.abs(radialError) < IDLE_SURFACE_LOCK_EPSILON then
			newRadialSpeed = 0
			local lockedPosition = gravityCenter.Position + (upVector * desiredRadiusFromCenter)
			hrp.CFrame = CFrame.lookAt(lockedPosition, lockedPosition + surfaceForward, upVector)
			hrp.AssemblyLinearVelocity = Vector3.zero
			hrp.AssemblyAngularVelocity = Vector3.zero
			playLocomotionAnimation(0, true, 0, 0)
			updateOrbitCamera(upVector, dt)
			return
		end
	end

	local newVel = (upVector * newRadialSpeed) + newTangent
	hrp.AssemblyLinearVelocity = newVel

	local tangentSpeed = newTangent.Magnitude
	local inputMag = localMove.Magnitude

	if inputMag > 0 and tangentSpeed < STUCK_SPEED_THRESHOLD then
		stuckTimeAcc += dt
	else
		stuckTimeAcc = 0
	end

	if stuckTimeAcc >= STUCK_TIME_THRESHOLD and desiredMove.Magnitude > 0 then
		local rescueSpeed = math.clamp(MOVE_SPEED * 0.72, STUCK_SPEED_THRESHOLD + 0.5, MAX_TANGENT_SPEED)
		newTangent = desiredMove.Unit * rescueSpeed
		newVel = (upVector * newRadialSpeed) + newTangent
		hrp.AssemblyLinearVelocity = newVel
		tangentSpeed = newTangent.Magnitude
	end

	local hrpInsideDepth = 0
	if planetRadius then
		hrpInsideDepth = math.max(0, planetRadius - centerDistance)
	end

	if hrpInsideDepth > 0.5 and not warnedInsideSphere then
		warnedInsideSphere = true
		warn(string.format("PlanetGravityController: HRP esta entrando en esfera (depth=%.2f)", hrpInsideDepth))
	elseif hrpInsideDepth <= 0.1 then
		warnedInsideSphere = false
	end

	if stuckTimeAcc >= STUCK_TIME_THRESHOLD then
		warn(string.format(
			"PlanetGravityController: posible atoro detectado | input=%.2f tangentSpeed=%.2f radialSpeed=%.2f centerDist=%.2f insideDepth=%.2f grounded=%s humanoidState=%s",
			inputMag,
			tangentSpeed,
			math.abs(newRadialSpeed),
			centerDistance,
			hrpInsideDepth,
			tostring(isGrounded),
			tostring(humanoid:GetState())
			))
		stuckTimeAcc = 0
	end

	if DEBUG_LOGS then
		debugTimeAcc += dt
		if debugTimeAcc >= DEBUG_INTERVAL then
			debugTimeAcc = 0
			print(string.format(
				"[PlanetDbg] input=%.2f tang=%.2f rad=%.2f dist=%.2f targetDist=%.2f inside=%.2f grounded=%s moveDir=%.2f floor=%s",
				inputMag,
				tangentSpeed,
				math.abs(newRadialSpeed),
				centerDistance,
				desiredRadiusFromCenter,
				hrpInsideDepth,
				tostring(isGrounded),
				humanoid.MoveDirection.Magnitude,
				tostring(humanoid.FloorMaterial)
				))
		end
	end

	playLocomotionAnimation(tangentSpeed, isGrounded, newRadialSpeed, localMove.Magnitude)

	-- Camara fija en tercera persona alineada al personaje y al up local del planeta.
	updateOrbitCamera(upVector, dt)

	-- Movimiento y orientacion quedan controlados exclusivamente por fisica custom.
end)
